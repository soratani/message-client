{
  "name": "@soratani-code/notification-sdk",
  "version": "0.1.0",
  "description": "A typed WebSocket notification SDK with reconnect, heartbeat, queue and event dispatcher.",
  "license": "MIT",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "websocket",
    "sdk",
    "notification",
    "typescript",
    "realtime"
  ],
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@msgpack/msgpack": "^2.8.0",
    "socket.io-client": "^4.8.3"
  }
}
